# Viabe Team — web app (apps/team-web) environment.
#
# Copy to apps/team-web/.env.local for local dev.
#
# NEXT_PUBLIC_* vars are bundled into client JavaScript. The remaining vars are
# SERVER-ONLY — used exclusively in route handlers (which run server-side) and
# never reach the browser. CI lint (no-cross-product-env-vars) rejects any
# non-public *_SECRET_KEY / *_AUTH_TOKEN / *_API_KEY var here EXCEPT the
# route-handler vars explicitly whitelisted in the lint rule.

# --- Supabase (client-side) ---
# The publishable key is RLS-enforced and safe to ship to the browser.
NEXT_PUBLIC_TEAM_SUPABASE_URL=
NEXT_PUBLIC_TEAM_SUPABASE_PUBLISHABLE_KEY=

# Public base URL of the web app.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Server-only — Twilio webhook route handler (VT-3.3b) ---
# Twilio auth token — used ONLY in the webhook route handler to verify the
# X-Twilio-Signature. Server-only; never bundled to the client. TEAM_ prefix
# per the Pillar 8 naming convention (all Viabe Team backend secrets).
TEAM_TWILIO_AUTH_TOKEN=
# Public URL Twilio is configured to POST to — the signature is computed over it.
TEAM_TWILIO_WEBHOOK_URL=http://localhost:3000/api/team/twilio/webhook

# --- Server-only — internal service auth ---
# REQUIRED — must match the value in apps/team-orchestrator/.env.local exactly.
# Server-only; never exposed to the client.
INTERNAL_API_SECRET=
# Orchestrator base URL the webhook forwards to.
TEAM_ORCHESTRATOR_URL=http://localhost:8001
