# Viabe Team — orchestrator (apps/team-orchestrator) environment.
#
# Copy to apps/team-orchestrator/.env.local for local dev.
#
# SERVER-ONLY SECRETS. Never NEXT_PUBLIC_-prefixed — CI lint
# (no-cross-product-env-vars) rejects any NEXT_PUBLIC_* var in this file.
# Deployed to Railway (per-service env).

# --- Supabase ---
TEAM_SUPABASE_URL=
TEAM_SUPABASE_PUBLISHABLE_KEY=
# Server-side key — bypasses RLS. Never expose to a client bundle.
TEAM_SUPABASE_SECRET_KEY=
# Direct Postgres DSN — migration runner (scripts/apply_migrations.py) + DBOS.
TEAM_SUPABASE_DB_URL=

# --- Anthropic ---
TEAM_ANTHROPIC_API_KEY=

# --- Twilio (WhatsApp / SMS) ---
TEAM_TWILIO_ACCOUNT_SID=
TEAM_TWILIO_AUTH_TOKEN=
TEAM_TWILIO_FROM_NUMBER=

# --- Razorpay (billing) ---
TEAM_RAZORPAY_KEY_ID=
TEAM_RAZORPAY_KEY_SECRET=
TEAM_RAZORPAY_WEBHOOK_SECRET=

# --- Resend (transactional email) ---
TEAM_RESEND_API_KEY=

# --- Pricing (paise; 1 INR = 100 paise) ---
FOUNDING_PRICE_PAISE=249900
STANDARD_PRICE_PAISE=499900
PRO_PRICE_PAISE=1499900
FOUNDING_SEATS_TOTAL=100

# --- Internal service auth ---
# 64-char random secret, distinct per environment, shared across services.
# Compared constant-time only; never logged.
INTERNAL_API_SECRET=

# --- Phone tokenisation (VT-3.3a) ---
# REQUIRED — salt for SHA-256 phone-number tokens. Generate via:
#   openssl rand -hex 32
TEAM_PHONE_HASH_SALT=

# --- VTR REF# keying secret (VT-281/VT-280) ---
# REQUIRED for the VTR de-identified views' keyed customer_ref = HMAC(customer_id, this).
# Generate via:  openssl rand -hex 32
# Startup is FAIL-LOUD if unset (bootstrap_vtr_ref_secret raises, logged at the lifespan) —
# Fazal sets this on the Railway orchestrator env; a missing key at deploy is BY DESIGN, not a bug.
VT_REF_HMAC_KEY=

# --- Sandbox by Quicko (business verification / Option F — VT-361) ---
# GSTIN lookup + reverse-penny-drop name bind. Creds from the Sandbox dashboard (PAYG wallet).
# Local dev: .viabe/secrets/sandbox.env holds lowercase sandbox_api_key=/sandbox_api_secret= — the
# run/canary remaps them to these UPPERCASE env names. Prod: set directly on Railway at cutover.
# ABSENT → verification fails CLOSED (status stays 'unverified'); never fakes verified.
SANDBOX_API_KEY=
SANDBOX_API_SECRET=

# --- LangSmith observability (VT-101) ---
# API key from app.smith.langchain.com — leave UNSET to disable tracing.
# Tracing failures are swallowed; the pipeline survives outages by design.
LANGSMITH_API_KEY=
# Structural dev/prod separation — set to viabe-team-prod in production env.
# Defaults to viabe-team-dev when unset.
LANGSMITH_PROJECT=viabe-team-dev
# LangGraph reads the LANGCHAIN_* names natively for auto-instrumentation of
# graph nodes; the LANGSMITH_* names above are read by our explicit
# decorators in orchestrator/observability/langsmith.py. Both point at the
# same backend project.
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=viabe-team-dev
