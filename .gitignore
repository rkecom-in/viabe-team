# Dependencies
node_modules/
.pnpm-store/

# Build output
.next/
dist/
build/
out/
*.tsbuildinfo
# next-env.d.ts is intentionally committed so CI typecheck works without a build.

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.uv-cache/
*.egg-info/

# Env
.env
.env.local
.env.*.local
!.env.example

# Editor / OS
.DS_Store
.idea/
.vscode/
*.log
# Audit logs under the Cowork pipeline are intentionally tracked despite
# the *.log rule above — they're durable evidence, not ephemeral output.
!.viabe/queue/done/**/*.log
!.viabe/notifications/cowork-catchup.log

# Test / coverage
coverage/
.vitest/
.pytest_cache/
supabase/
.running/
.viabe/secrets/

# Cowork runtime state (NOT tracked — substrate lives in .viabe/sprint/*.md
# and docs/clau/entries/*.md). Queue dirs regenerate per task.
.viabe/queue/
.viabe/sprint/.lock
.viabe/sprint/.next-id.bak
migrations/.lock
.viabe/queue/*/status
.viabe/daemon/STOP
.viabe/daemon/*.pid
.claude/scheduled_tasks.lock

# VT-252 (security): raw Cowork session-export dirs carry permissionMode:bypassPermissions
# + Supabase magic-link auth tokens (token=... URLs) in metadata.json — must NEVER be
# committed. Curated *.md exports (token-scrubbed) may still be tracked deliberately.
cowork_sessions/session-export-*/
