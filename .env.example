# Viabe Team — environment variables (Phase 1).
# Copy to `.env` and fill in. Never commit `.env`.
#
# RULE: Viabe Team owns its config surface. Do NOT reference another
# product's env vars (anything prefixed `REPORTS_`) — CI fails on it via the
# no-cross-product-env-vars lint rule.

# --- Pricing (paise; 1 INR = 100 paise) ---
FOUNDING_PRICE_PAISE=249900
STANDARD_PRICE_PAISE=499900
PRO_PRICE_PAISE=1499900

# --- Founding cohort ---
FOUNDING_SEATS_TOTAL=100

# --- Anthropic (orchestrator + ingestion worker) ---
ANTHROPIC_API_KEY=

# --- Supabase / Postgres (pgvector) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# --- DBOS (orchestrator workflow engine) ---
DBOS_DATABASE_URL=

# --- Twilio (team-web webhook receiver) ---
TEAM_TWILIO_ACCOUNT_SID=
TEAM_TWILIO_AUTH_TOKEN=

# --- Razorpay (team-web webhook receiver) ---
TEAM_RAZORPAY_KEY_ID=
TEAM_RAZORPAY_KEY_SECRET=
TEAM_RAZORPAY_WEBHOOK_SECRET=

# --- Apify (ingestion worker) ---
APIFY_TOKEN=

# --- Sarvam AI (ingestion worker) ---
SARVAM_API_KEY=

# --- Web app ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
