# Viabe Team — environment variables (Phase 1).
# Copy to `.env` and fill in. Never commit `.env`.
#
# RULES (enforced by CI):
# - No cross-product env vars: anything prefixed `REPORTS_` is forbidden.
# - Supabase key discipline (VT-2): ONLY the publishable + secret keys are
#   allowed. The legacy `SUPABASE_ANON_KEY` and `SUPABASE_SERVICE_ROLE_KEY`
#   are forbidden in code, env files, and docs — the env lint fails on them.

# --- Pricing (paise; 1 INR = 100 paise) ---
FOUNDING_PRICE_PAISE=249900
STANDARD_PRICE_PAISE=499900
PRO_PRICE_PAISE=1499900

# --- Founding cohort ---
FOUNDING_SEATS_TOTAL=100

# --- Anthropic (orchestrator + ingestion worker) ---
ANTHROPIC_API_KEY=

# --- Supabase (shared viabe-team Postgres + pgvector) ---
# REST API URL, e.g. https://<project-ref>.supabase.co
TEAM_SUPABASE_URL=
# Client-side key — RLS enforced.
TEAM_SUPABASE_PUBLISHABLE_KEY=
# Server-side key — bypasses RLS (the service-role path).
TEAM_SUPABASE_SECRET_KEY=
# Direct Postgres DSN for the migration runner (psycopg) and DBOS. This is the
# project's direct connection string, NOT the REST URL above:
#   postgres://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres
TEAM_SUPABASE_DB_URL=

# --- Internal service auth (VT-2.6) ---
# 64-char random secret, distinct per environment, shared across web /
# orchestrator / worker. Compared constant-time only; never logged.
INTERNAL_API_SECRET=

# --- Twilio (team-web webhook receiver) ---
TEAM_TWILIO_ACCOUNT_SID=
TEAM_TWILIO_AUTH_TOKEN=

# --- Razorpay (team-web webhook receiver) ---
TEAM_RAZORPAY_KEY_ID=
TEAM_RAZORPAY_KEY_SECRET=
TEAM_RAZORPAY_WEBHOOK_SECRET=

# --- Apify (ingestion worker) ---
APIFY_TOKEN=

# --- Sarvam AI (ingestion worker) ---
SARVAM_API_KEY=

# --- Web app ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
