# Viabe Team — web app (apps/team-web) environment.
#
# Copy to apps/team-web/.env.local for local dev.
#
# NEXT_PUBLIC_* vars are bundled into client JavaScript. The remaining vars are
# SERVER-ONLY — used exclusively in route handlers (which run server-side) and
# never reach the browser. CI lint (no-cross-product-env-vars) rejects any
# non-public *_SECRET_KEY / *_AUTH_TOKEN / *_API_KEY var here EXCEPT the
# route-handler vars explicitly whitelisted in the lint rule.

# --- Supabase (client-side) ---
# The publishable key is RLS-enforced and safe to ship to the browser.
NEXT_PUBLIC_TEAM_SUPABASE_URL=
NEXT_PUBLIC_TEAM_SUPABASE_PUBLISHABLE_KEY=

# Public base URL of the web app.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# VT-95 — landing-page plan DISPLAY prices in ₹ (rupees). Pillar 7: prices are config, not
# code literals — the authoritative paise source is the orchestrator config/plans.yaml; these
# mirror the rupee display value (the no-price-literals gate greps paise, not these).
NEXT_PUBLIC_FOUNDING_PRICE_INR=2,499
NEXT_PUBLIC_STANDARD_PRICE_INR=4,999
NEXT_PUBLIC_PRO_PRICE_INR=14,999

# VT-429 — single-plan launch gate (owner-facing mirror of the orchestrator's authoritative
# server-side offered_tiers allowlist in config/plans.yaml). Comma-separated; controls which plan
# cards render on the plan-selection/marketing surface. At launch: STANDARD only. FAIL-CLOSED — an
# absent/blank value offers NOTHING (no cards), never offer-all; widening = add a tier here AND to
# the orchestrator config/plans.yaml offered_tiers list. The LOAD-BEARING gate is server-side.
NEXT_PUBLIC_OFFERED_TIERS=standard

# --- Server-only — Twilio webhook route handler (VT-3.3b) ---
# Twilio auth token — used ONLY in the webhook route handler to verify the
# X-Twilio-Signature. Server-only; never bundled to the client. TEAM_ prefix
# per the Pillar 8 naming convention (all Viabe Team backend secrets).
TEAM_TWILIO_AUTH_TOKEN=
# Public URL Twilio is configured to POST to — the signature is computed over it.
TEAM_TWILIO_WEBHOOK_URL=http://localhost:3000/api/team/twilio/webhook

# --- Server-only — internal service auth ---
# REQUIRED — must match the value in apps/team-orchestrator/.env.local exactly.
# Server-only; never exposed to the client.
INTERNAL_API_SECRET=
# Orchestrator base URL the webhook forwards to.
TEAM_ORCHESTRATOR_URL=http://localhost:8001

# --- Server-only — VT-89 Razorpay webhook ---
# Razorpay webhook signing secret (Razorpay dashboard -> Team webhook).
# Single canonical name — no env-suffix. LIVE secret is NEEDS-FAZAL, hard-gated by VT-93-N1 + VT-329.
RAZORPAY_WEBHOOK_SECRET=

# --- Client-exposed — VT-91 Razorpay Checkout (PUBLISHABLE key, not a secret) ---
# Razorpay publishable key_id for the hosted Checkout (card capture). TEST key for dev;
# LIVE key is NEEDS-FAZAL. Empty = the subscribe page creates the subscription but skips
# the hosted card step (dev/stub).
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# --- Server-only — VT-211 Integration Agent onboarding (/team/onboard) ---
# Tenant UUID the onboarding page operates on. Phase-1 single-tenant
# assumption (Fazal's own tenant). Populate from a tenants-table lookup;
# Phase-2 multi-tenant resolution lives in a separate row.
FAZAL_TENANT_ID=
