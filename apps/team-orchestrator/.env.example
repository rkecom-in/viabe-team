# Viabe Team — orchestrator (apps/team-orchestrator) environment.
#
# Copy to apps/team-orchestrator/.env.local for local dev.
#
# SERVER-ONLY SECRETS. Never NEXT_PUBLIC_-prefixed — CI lint
# (no-cross-product-env-vars) rejects any NEXT_PUBLIC_* var in this file.
# Deployed to Railway (per-service env).

# --- Supabase ---
TEAM_SUPABASE_URL=
TEAM_SUPABASE_PUBLISHABLE_KEY=
# Server-side key — bypasses RLS. Never expose to a client bundle.
TEAM_SUPABASE_SECRET_KEY=
# Direct Postgres DSN — migration runner (scripts/apply_migrations.py) + DBOS.
TEAM_SUPABASE_DB_URL=

# --- Anthropic ---
TEAM_ANTHROPIC_API_KEY=

# --- Twilio (WhatsApp / SMS) ---
TEAM_TWILIO_ACCOUNT_SID=
TEAM_TWILIO_AUTH_TOKEN=
TEAM_TWILIO_FROM_NUMBER=

# --- Razorpay (billing) ---
TEAM_RAZORPAY_KEY_ID=
TEAM_RAZORPAY_KEY_SECRET=
TEAM_RAZORPAY_WEBHOOK_SECRET=

# --- Resend (transactional email) ---
TEAM_RESEND_API_KEY=

# --- Pricing (paise; 1 INR = 100 paise) ---
FOUNDING_PRICE_PAISE=249900
STANDARD_PRICE_PAISE=499900
PRO_PRICE_PAISE=1499900
FOUNDING_SEATS_TOTAL=100

# --- Internal service auth ---
# 64-char random secret, distinct per environment, shared across services.
# Compared constant-time only; never logged.
INTERNAL_API_SECRET=

# --- Phone tokenisation (VT-3.3a) ---
# REQUIRED — salt for SHA-256 phone-number tokens. Generate via:
#   openssl rand -hex 32
TEAM_PHONE_HASH_SALT=
