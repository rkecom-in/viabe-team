#!/usr/bin/env bash
# VT-245 — local pre-push gate.
#
# main protection is an account-level ruleset; "Require status checks to
# pass" was turned OFF 2026-05-30, so CI no longer blocks merges. This
# hook is the safety gate: it runs the FAST CI-equivalent suite locally
# and aborts the push on failure, so "green locally ≈ green in CI".
#
# Scope = FAST checks only (ruff + dep-less smoke + web tsc/vitest/lint +
# a conditional orchestrator docker build). It deliberately EXCLUDES the
# slow live-DB migration tests, canaries, and integration suites — those
# run in CI / on demand.
#
# Escape hatch: `git push --no-verify` skips this hook (use sparingly).
#
# Install: scripts/install-hooks.sh

set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT" || exit 1

# VT-70: source local API-key secrets (presence-gated) so real-call canaries
# (e.g. the voyage embed canary) RUN fail-not-skip in local pre-push — the DR-15
# gate per CLAUDE.md (CI is the non-blocking backstop). .viabe/secrets is
# gitignored; degrades gracefully (canary skips) for anyone without the file.
if [ -f "$REPO_ROOT/.viabe/secrets/voyage.env" ]; then
  set -a; . "$REPO_ROOT/.viabe/secrets/voyage.env"; set +a
fi

FAIL=0
say()  { printf '\033[1;36m[pre-push]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[pre-push WARN]\033[0m %s\n' "$*"; }
err()  { printf '\033[1;31m[pre-push FAIL]\033[0m %s\n' "$*"; }

# --- Determine the changed files across the push range ----------------
# stdin: <local_ref> <local_sha> <remote_ref> <remote_sha> per ref.
# Fall back to diff against origin/main when the remote sha is unknown
# (new branch -> remote_sha is all-zeros).
ZERO="0000000000000000000000000000000000000000"
RANGE_BASE=""
while read -r _local_ref local_sha _remote_ref remote_sha; do
  [ -z "${local_sha:-}" ] && continue
  if [ "$remote_sha" = "$ZERO" ] || [ -z "$remote_sha" ]; then
    RANGE_BASE="$(git merge-base origin/main "$local_sha" 2>/dev/null || echo origin/main)"
  else
    RANGE_BASE="$remote_sha"
  fi
  RANGE_HEAD="$local_sha"
done

# No stdin (manual run) -> compare working HEAD against origin/main.
if [ -z "$RANGE_BASE" ]; then
  RANGE_BASE="$(git merge-base origin/main HEAD 2>/dev/null || echo origin/main)"
  RANGE_HEAD="HEAD"
fi

CHANGED="$(git diff --name-only "$RANGE_BASE" "$RANGE_HEAD" 2>/dev/null || true)"
# VT-316 — NEVER silently skip the gate on an empty change-set. A previous bug
# let a degenerate/empty push range (e.g. the hook's stdin consumed by a
# compound `git commit <<EOF && git push` command) compute zero files and
# `exit 0` PASS — pushing unverified code. An empty range is only LEGITIMATE
# when HEAD is genuinely not ahead of origin/main (real no-op push). Otherwise:
# recover via the HEAD-vs-origin/main diff, and if even THAT is empty while
# commits exist, FAIL LOUD rather than pass blind.
if [ -z "$CHANGED" ]; then
  _ahead="$(git rev-list --count origin/main..HEAD 2>/dev/null || echo 0)"
  _fallback="$(git diff --name-only \
    "$(git merge-base origin/main HEAD 2>/dev/null || echo origin/main)" HEAD \
    2>/dev/null || true)"
  if [ -n "$_fallback" ]; then
    warn "push range yielded no files (suspect range — base=$RANGE_BASE head=$RANGE_HEAD); \
falling back to HEAD vs origin/main (VT-316)."
    CHANGED="$_fallback"
  elif [ "${_ahead:-0}" != "0" ]; then
    err "empty changed-file set, but HEAD is ${_ahead} commit(s) ahead of origin/main — \
the push range was not determined correctly. Refusing to skip the gate silently (VT-316). \
Re-run the push as a STANDALONE command (not chained after a heredoc), or --no-verify if truly intended."
    exit 1
  else
    say "no changed files + HEAD not ahead of origin/main — genuinely nothing to check."
    exit 0
  fi
fi

# VT-316 testability: PREPUSH_RANGE_ONLY short-circuits AFTER range resolution
# (prints the resolved change-set, runs no suite) so the empty-range fail-loud
# logic can be exercised deterministically by scripts/test_prepush_range.sh.
if [ -n "${PREPUSH_RANGE_ONLY:-}" ]; then
  printf 'RANGE_OK\n%s\n' "$CHANGED"
  exit 0
fi

changed_match() { printf '%s\n' "$CHANGED" | grep -qE "$1"; }

ORCH_CHANGED=0; WEB_CHANGED=0; DOCKER_RELEVANT=0
changed_match '^apps/team-orchestrator/'     && ORCH_CHANGED=1
changed_match '^apps/team-ingestion-worker/' && ORCH_CHANGED=1
changed_match '^packages/team-shared/'       && ORCH_CHANGED=1
changed_match '^apps/team-web/'              && WEB_CHANGED=1
changed_match '^apps/team-orchestrator/(Dockerfile|pyproject\.toml|src/)' && DOCKER_RELEVANT=1

# --- 1. Python: ruff + dep-less smoke (catches importorskip-guard misses)
if [ "$ORCH_CHANGED" = 1 ]; then
  say "ruff check (orchestrator + ingestion-worker)"
  uvx ruff check apps/team-orchestrator apps/team-ingestion-worker || { err "ruff"; FAIL=1; }

  say "smoke pytest (uv --no-project --with pytest) — dep-less, mirrors CI 'test' job"
  ( cd apps/team-orchestrator && uv run --no-project --with pytest pytest -q ) \
    || { err "orchestrator smoke pytest"; FAIL=1; }
fi

# --- 2. team-web: tsc + vitest + lint ---------------------------------
if [ "$WEB_CHANGED" = 1 ]; then
  say "team-web tsc --noEmit"
  ( cd apps/team-web && npx --no-install tsc --noEmit ) || { err "tsc"; FAIL=1; }
  say "team-web vitest run"
  ( cd apps/team-web && npx --no-install vitest run ) || { err "vitest"; FAIL=1; }
  say "team-web lint"
  pnpm --filter @viabe/team-web lint || { err "team-web lint"; FAIL=1; }
fi

# --- 3. orchestrator docker build (Railway deploys via Docker) --------
# Conditional + skip-when-unavailable (Cowork ruling): only when
# orchestrator image inputs changed AND the docker daemon is up. A bad
# RAILWAY_TOKEN (auth) is NOT catchable here — only build/dep/startup.
if [ "$DOCKER_RELEVANT" = 1 ]; then
  if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
    say "docker build orchestrator image (catches build/dep/startup, NOT auth)"
    docker build -f apps/team-orchestrator/Dockerfile -t viabe-orch:prepush apps/team-orchestrator \
      || { err "docker build orchestrator"; FAIL=1; }
  else
    warn "docker unavailable; orchestrator image build NOT verified locally — CI/Railway remote build is the backstop."
  fi
fi

# --- 4. orchestrator + migrations DB jobs (VT-260) --------------------
# The dep-less smoke (step 1) does NOT exercise the DB-backed CI jobs
# (`orchestrator` = DBOS+postgres, `migrations`) — exactly where failures slip
# through to CI (vt-163 failed `orchestrator` x2). When orchestrator code changed
# AND a local Postgres is reachable, run those jobs against a throwaway DB so the
# failure is caught BEFORE push. Graceful-degrade (warn, don't block) when pg is
# absent — CI's fresh ephemeral pg is the backstop, same pattern as the docker step.
#
# Opt-out: VIABE_PREPUSH_SKIP_DB=1. Override the admin DSN: VIABE_PREPUSH_DB_URL
# (default postgres://localhost:5432/postgres).
if [ "$ORCH_CHANGED" = 1 ] && [ "${VIABE_PREPUSH_SKIP_DB:-0}" != 1 ]; then
  ADMIN_DSN="${VIABE_PREPUSH_DB_URL:-postgres://localhost:5432/postgres}"
  if command -v pg_isready >/dev/null 2>&1 \
     && command -v psql >/dev/null 2>&1 \
     && pg_isready -d "$ADMIN_DSN" -q >/dev/null 2>&1; then
    DBNAME="viabe_prepush_$$"
    DBURL="${ADMIN_DSN%/*}/$DBNAME"
    say "local Postgres reachable — running migrations + orchestrator DB jobs vs throwaway $DBNAME"
    # VT-310: reap leftover canary/throwaway DBs FIRST. They hold GRANTs on the
    # shared roles, so without this the DROP ROLE below silently fails → stale
    # grants → the RLS migration tests false-fail with "permission denied"
    # (bit the L2 + L3 builds 3x). The reaper drops test DBs + the shared roles.
    VIABE_REAP_DSN="$ADMIN_DSN" bash "$REPO_ROOT/scripts/reap_test_dbs.sh" >/dev/null 2>&1 || true
    # Mimic CI's FRESH cluster: mig 015/027 CREATE ROLE is NOT idempotent, so
    # drop the throwaway DB FIRST (clears its privilege deps), THEN the cluster
    # roles, THEN recreate — else apply halts at 015 (VT-260 / local-halt lesson).
    psql "$ADMIN_DSN" -tAqc "DROP DATABASE IF EXISTS $DBNAME WITH (FORCE)" >/dev/null 2>&1
    for _r in app_role app_operator_role rls_tester; do
      psql "$ADMIN_DSN" -tAqc "DROP ROLE IF EXISTS $_r" >/dev/null 2>&1
    done
    psql "$ADMIN_DSN" -tAqc "CREATE DATABASE $DBNAME" >/dev/null 2>&1
    # migrations job (fresh DB → clean-apply assertions hold) FIRST, then the
    # orchestrator job (fixtures re-apply = noop). Exclude the known SIGKILL-timing
    # flake (test_dbos_auto_resumes_after_sigkill) — a flaky test must not gate
    # every push; CI still runs it (Cowork ruling VT-260).
    say "  migrations job"
    ( cd apps/team-orchestrator \
      && DATABASE_URL="$DBURL" uv run --no-project --with 'psycopg[binary]' --with pytest \
         pytest tests/test_migrations.py -q ) \
      || { err "migrations job (pre-push DB coverage)"; FAIL=1; }
    say "  orchestrator job (-k 'not sigkill')"
    ( cd apps/team-orchestrator \
      && DATABASE_URL="$DBURL" RUN_INTEGRATION_TESTS=1 \
         INTERNAL_API_SECRET=prepush-local TEAM_PHONE_HASH_SALT=prepush-local \
         uv run pytest tests/orchestrator/ -q -k 'not sigkill' ) \
      || { err "orchestrator job (pre-push DB coverage)"; FAIL=1; }
    psql "$ADMIN_DSN" -tAqc "DROP DATABASE IF EXISTS $DBNAME WITH (FORCE)" >/dev/null 2>&1
  else
    warn "local Postgres not reachable; orchestrator + migrations DB jobs NOT run locally — CI is the backstop (set VIABE_PREPUSH_DB_URL to enable)."
  fi
fi

if [ "$FAIL" -ne 0 ]; then
  err "push aborted. Fix the above, or bypass with: git push --no-verify"
  exit 1
fi
say "all fast checks passed — pushing."
exit 0
