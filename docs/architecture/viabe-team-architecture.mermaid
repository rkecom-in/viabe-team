    subgraph infra[Substrate]
        DBOS["DBOS Workflows<br/>CL-36"]:::done
        PG["Supabase Postgres<br/>RLS app_current_tenant"]:::done
        REPO["viabe-team repo<br/>+ branch protection"]:::done
        TWILIO["Twilio account<br/>CL-50"]:::done
        WAT["WhatsApp Templates<br/>Tier-A 5 + Tier-B 17"]:::inflight
        DAEMON["Agent-Loop Daemon<br/>VT-166 STOPd"]:::done
