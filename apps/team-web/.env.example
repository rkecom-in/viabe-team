# Viabe Team — web app (apps/team-web) environment.
#
# Copy to apps/team-web/.env.local for local dev.
#
# FRONTEND-BOUND VARS ONLY. Every var here is NEXT_PUBLIC_-prefixed and is
# bundled into client JavaScript. Server secrets live in the orchestrator /
# ingestion-worker env files — never here. CI lint (no-cross-product-env-vars)
# rejects non-public *_SECRET_KEY / *_AUTH_TOKEN / *_API_KEY vars in this file.

# Supabase — client-side access. The publishable key is RLS-enforced and safe
# to ship to the browser.
NEXT_PUBLIC_TEAM_SUPABASE_URL=
NEXT_PUBLIC_TEAM_SUPABASE_PUBLISHABLE_KEY=

# Public base URL of the web app.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
