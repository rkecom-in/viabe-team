%% Viabe Team — Architecture Flow with Completion-State Color Coding
%% Generated 2026-05-26 14:10 IST by Cowork. Light-mode lock per CLAUDE.md
%% dashboard-discipline rule. DO NOT override theme to dark.
%% Color legend:
%%   done      — shipped to main (green fill, green border)
%%   inflight  — pr-ready / queued / in-flight (blue fill, blue border)
%%   backlog   — Sprint 1 critical-path, not started (amber fill, amber border)
%%   held      — SHIP-GATE / Fazal-owned / phantom-Done corrected (red fill, red border)
%%   deferred  — Phase 2+ / post-launch (gray fill, dashed border)

flowchart LR
    subgraph inbound[Inbound]
        WA["WhatsApp Webhook<br/>VT-3.3"]:::done
        SCHED["Scheduled Triggers<br/>VT-28 shells"]:::done
        TG["Telegram Inbound<br/>OpsAssistant"]:::done
    end

    subgraph pipeline[Orchestrator Pipeline]
        PRE["Pre-Filter Gate<br/>VT-31"]:::done
        ORCH["Orchestrator-Agent<br/>Opus 4.7 · VT-32"]:::done
        HLIM["Hard Limits<br/>VT-35"]:::done
        SUP["Supervisor<br/>VT-3.4"]:::done
        SR["SR-Agent<br/>VT-4 ship-thin"]:::done
        SE["Self-Evaluate<br/>VT-36"]:::done
        CP["CampaignPlan v1.0<br/>VT-37"]:::done
        TC["Tool-Contract<br/>VT-39"]:::done
        COMP["Unified Composer<br/>VT-30"]:::backlog
        OUT["WhatsApp + Telegram<br/>dispatch"]:::backlog
    end

    subgraph memory[Memory Tiers]
        L0["L0 Workspace<br/>VT-126"]:::backlog
        L1["L1 KG pgvector<br/>migration 019"]:::done
        L2["L2 Episodic<br/>VT-7.3"]:::deferred
        L3["L3 Mem0<br/>CL-324"]:::deferred
        OI["owner_inputs<br/>VT-146 SHIP-GATE"]:::held
    end

    subgraph obs[Observability Stack]
        PII["PII Redactor<br/>VT-104"]:::done
        PLOG["pipeline_log<br/>VT-102"]:::done
        COST["Cost Dashboard<br/>VT-103"]:::done
        LF["Pydantic Logfire EU<br/>VT-171 honors CL-56"]:::done
        RTRACE["Reasoning Trace<br/>VT-104"]:::done
    end

    subgraph billing[Billing]
        ATTR["attributions table<br/>VT-175 pr-ready"]:::inflight
        D39["Day-39 Evaluator<br/>VT-175 pr-ready"]:::inflight
        SHELLS["Shell to Real Bodies<br/>VT-176 queued"]:::inflight
        PAY["razorpay_events<br/>migration 004"]:::done
        SUB["subscriptions<br/>migration 003"]:::done
        REF["Refund Execution"]:::backlog
